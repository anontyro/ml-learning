{
  "meta": {
    "author": "alex"
  },
  "name": "extract-themes",
  "version": "1.0.0",
  "schema": {
    "type": "object",
    "properties": {
      "themes": {
        "type": "array",
        "items": { "type": "string" }
      },
      "blockers": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "description": {
              "description": {
                "type": "string"
              },
              "owner": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "required": ["themes", "blockers"]
  },
  "template_lines": [
    "Analyze the following text. Extract key themes and blockers.",
    "Text: {context}",
    "Output ONLY valid JSON."
  ]
}
