{
  "meta": {
    "author": "alex"
  },
  "name": "extract-themes",
  "version": "1.0.0",
  "schema": {
    "type": "object",
    "properties": {
      "themes": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "description": { "type": "string" }
          },
          "required": ["name", "description"]
        }
      },
      "blockers": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "description": { "type": "string" }
          },
          "required": ["name", "description"]
        }
      }
    },
    "required": ["themes", "blockers"]
  },
  "template_lines": [
    "You are a data extraction agent. Analyze the text and extract themes and blockers into structured JSON.",
    "",
    "Output format (must be valid JSON):",
    "{{",
    "  \"themes\": [",
    "    {{ \"name\": \"theme name\", \"description\": \"theme description\" }}",
    "  ],",
    "  \"blockers\": [",
    "    {{ \"name\": \"blocker name\", \"description\": \"blocker description\" }}",
    "  ]",
    "}}",
    "",
    "Requirements:",
    "- Output ONLY the JSON object, nothing else",
    "- No markdown, no code blocks, no backticks, no explanations",
    "- If no themes or blockers found, return empty arrays: []",
    "- Ensure the JSON is complete and valid (all brackets closed, proper commas)",
    "",
    "Text: {context}"
  ]
}
