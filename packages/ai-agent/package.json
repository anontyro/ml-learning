{
  "name": "@ai-agent/core",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./ingest": {
      "types": "./dist/ingest.d.ts",
      "require": "./dist/ingest.js",
      "import": "./dist/ingest.js"
    },
    "./generate": {
      "types": "./dist/generate.d.ts",
      "require": "./dist/generate.js",
      "import": "./dist/generate.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "require": "./dist/config.js",
      "import": "./dist/config.js"
    },
    "./prompts": {
      "types": "./dist/utils/prompt/index.d.ts",
      "require": "./dist/utils/prompt/index.js",
      "import": "./dist/utils/prompt/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "start": "tsx src/index.ts",
    "ingest": "tsx src/ingest.ts",
    "generate": "tsx src/generate.ts"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.57.0",
    "@langchain/community": "^1.1.22",
    "@langchain/core": "^1.1.31",
    "@langchain/ollama": "^1.2.6",
    "chromadb": "^3.3.2",
    "langchain": "^1.2.30",
    "mammoth": "^1.11.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
